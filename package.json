{
  "name": "GlassyWeb-Browser",
  "version": "1.1.1",
  "description": "Your personal Glassy Browser",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --windows"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ctrlaltkaas.glassyweb",
    "productName": "GlassyWeb",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GlassyWeb"
    },
    "directories": {
      "output": "dist"
    }
  },
  "author": "CtrlAltKaasYT",
  "license": "MIT"
}