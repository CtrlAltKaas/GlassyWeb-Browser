{
  "name": "GlassyWeb-Browser",
  "version": "1.2.1",
  "description": "Your personal Glassy Browser",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --windows"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ctrlaltkaas.glassyweb",
    "productName": "GlassyWeb",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GlassyWeb",
      "include": "build/installer.nsh"
    },
    "protocols": [
      { "name": "HTTP",  "schemes": ["http"] },
      { "name": "HTTPS", "schemes": ["https"] }
    ],
    "fileAssociations": [
      { "ext": "html", "name": "HTML Document", "description": "HTML Document", "role": "Viewer" },
      { "ext": "htm",  "name": "HTML Document", "description": "HTML Document", "role": "Viewer" },
      { "ext": "pdf",  "name": "PDF Document",  "description": "PDF Document",  "role": "Viewer" }
    ],
    "directories": {
      "output": "dist"
    }
  },
  "author": "CtrlAltKaasYT",
  "license": "MIT"
}
